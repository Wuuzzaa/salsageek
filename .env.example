# SalsaGeek - Lokale Konfiguration
# Kopiere diese Datei nach .env und fülle deine Werte aus

# Dein GitHub Personal Access Token (PAT)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Dein Repository Name (z.B. nutzername/salsageek)
GITHUB_REPO=username/salsageek

# Optional: Flask Secret Key
SECRET_KEY=entwicklung-geheim
